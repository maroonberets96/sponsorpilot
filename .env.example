# Copy this file to .env and fill in your own values. .env is gitignored.

# --- Input files (in data/input/) ---
# Your base CV as a .docx. Any filename; point this at it.
CV_FILENAME=cv.docx
# UK sponsor-licence register .xlsx (only needed for UK jobs mode). Download the
# latest "Worker and Temporary Worker" list from gov.uk and drop it in data/input/.
SPONSOR_XLSX_FILENAME=Worker_and_Temporary_Worker.xlsx

# --- Job boards (jobs-first mode; at least one required) ---
# Adzuna - free key at https://developer.adzuna.com (works for UK and Canada)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
# Reed - free key at https://www.reed.co.uk/developers (UK only)
REED_API_KEY=your_reed_api_key
# Jooble - free key at https://jooble.org/api/about (used for Canada)
JOOBLE_API_KEY=your_jooble_api_key

# --- Job search tuning (optional) ---
# JOB_LOCATION=London          # UK search centre
# JOB_DISTANCE_MILES=20        # radius around JOB_LOCATION
# JOB_LOCATION_CA=Toronto      # Canada city; leave unset to search all of Canada

# --- LLM providers (waterfall: NVIDIA -> Groq -> Ollama Cloud) ---
# NVIDIA NIM API - primary. Free key at https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here
# Groq - fallback 2. Free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# Ollama Cloud - fallback 3, via local daemon after `ollama signin`.
# Model must end with -cloud (local models are never used).
OLLAMA_CLOUD_MODEL=gpt-oss:120b-cloud
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Optional model overrides (defaults in src/config.py) ---
# NVIDIA_MATCH_MODEL=qwen/qwen3.5-122b-a10b
# NVIDIA_WRITE_MODEL=qwen/qwen3.5-397b-a17b
# NVIDIA_FALLBACK_MODEL=deepseek-ai/deepseek-v4-flash
# GROQ_MODEL=llama-3.3-70b-versatile
